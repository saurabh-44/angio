# Caddy auto-provisions and auto-renews a Let's Encrypt certificate for
# this domain on first request. The `api` subdomain must already have an
# A record pointing at this VPS before Caddy can complete the ACME
# challenge.
api.jainildesai.com {
	reverse_proxy server:4000
}

# Web portal — the React SPA. Auto-TLS like the api subdomain; needs an
# `app` A record pointing at this VPS before the first request.
app.jainildesai.com {
	reverse_proxy web:80
}
