# Leave empty in dev — Vite's dev proxy forwards /api/* to the
# backend at localhost:4000 server-side, so requests are same-origin
# in the browser. Only set this when the API is on a different
# domain in production.
VITE_API_BASE_URL=

# Google Maps JavaScript API key. The map view in the donor + admin
# dashboards gracefully falls back to a list with "open in Maps"
# links when this is empty, so it's optional for dev.
VITE_GOOGLE_MAPS_API_KEY=
