NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
PUBLIC_URL=http://localhost:4000

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/angio

# JWT — both secrets MUST be at least 32 characters
JWT_ACCESS_SECRET=replace-with-a-long-random-string-min-32-chars
JWT_REFRESH_SECRET=replace-with-another-long-random-string-min-32-chars
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=2

# Cookies
COOKIE_SAMESITE=lax
COOKIE_SECURE=false
# COOKIE_DOMAIN=

# Primary NGO admin — seeded on first boot if no ngo_admin exists.
# Created with forcePasswordChange=true so the delivery password is
# rotated on first sign-in.
PRIMARY_NGO_ADMIN_EMAIL=admin@yourngo.org
PRIMARY_NGO_ADMIN_PASSWORD=change-me-on-first-login
PRIMARY_NGO_ADMIN_NAME=NGO Admin

# Mail — set MAIL_HOST (Gmail SMTP w/ app password works) or
# RESEND_API_KEY to send real emails. Without either, OTPs + temp
# passwords print to the server console (dev only).
RESEND_API_KEY=
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM_NAME=Environ
MAIL_FROM_EMAIL=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=angio

# Razorpay — get test keys from https://dashboard.razorpay.com/app/keys
# (test mode keys start with rzp_test_). Leave empty to disable
# online donations; offline NGO-admin recording keeps working.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Per-tree price in INR for donor self-service sponsorship.
TREE_UNIT_PRICE_INR=200
