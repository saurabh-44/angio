# Production env template for the Dockerized API.
# On the VPS:  cp server/.env.production.example server/.env  then fill in.
# NEVER commit the real server/.env.
#
# MONGODB_URI is injected by docker-compose (mongodb://mongo:27017/angio)
# so you do NOT need to set it here.

NODE_ENV=production
PORT=4000

# Public web origin that talks to this API (your hosted web client).
# Used for CORS + cookie scope. The native app uses Bearer tokens and is
# allowed separately. Set to your web portal URL once it's hosted.
CLIENT_ORIGIN=https://jainildesai.com
PUBLIC_URL=https://api.jainildesai.com

# JWT — generate fresh, each >=32 chars:  openssl rand -base64 48
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL_MIN=15
JWT_REFRESH_TTL_DAYS=2

# Cookies — HTTPS in prod, so secure must be on. sameSite=none lets the
# hosted web client send cookies cross-site to the api subdomain.
COOKIE_SECURE=true
COOKIE_SAMESITE=none

# Seed admin (created on first boot, forced password change on login).
PRIMARY_NGO_ADMIN_EMAIL=admin@jainildesai.com
PRIMARY_NGO_ADMIN_PASSWORD=change-me-on-first-login
PRIMARY_NGO_ADMIN_NAME=NGO Admin

# Mail — set one of these for real OTP/email delivery in prod.
RESEND_API_KEY=
MAIL_HOST=
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM_NAME=Environ
MAIL_FROM_EMAIL=

# Cloudinary — required for plant/maintenance photo upload.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=angio

# Razorpay — required for online sponsorship payments.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
TREE_UNIT_PRICE_INR=200
